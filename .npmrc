# TeleBox vendored plugins (e.g. quote/vendor from TeleBoxOrg/quote-api) pull in
# packages whose peerDependencies lag behind the project's pinned versions —
# notably smartcrop-sharp@2.0.8 wants sharp@^0.32.5 while the project uses
# sharp@^0.34.3 (runtime-compatible, peer range just not bumped upstream).
# legacy-peer-deps keeps `npm install` (and the .update plugin) from hard-failing
# with ERESOLVE. Precise per-package overrides also live in package.json.
legacy-peer-deps=true
